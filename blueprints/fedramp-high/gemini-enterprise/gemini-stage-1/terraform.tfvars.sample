# Stage 0 State Bucket (Required for remote state access)
stage_0_state_bucket = "sedev-gemini-enterprise-tf-state-sedev-test-mike-iac-core-0"

# Domain you want to use to host your Gemini Enterprise Web App
gemini_enterprise_domain = "gemini.yourdomain.gov"

# Gemini Enterprise ID (Output from Gem4Gov CLI)
gemini_config_id   = "your_gemini_config_id"

# SSL Cert Name (Pre-uploaded to Google Cloud Certificate Manager)
ssl_certificate_name = "your-cert-name-here"