main_project_id = "prefx-main-xxx-x"
prefix          = "prefx"
environment     = "dev"

# Get your organization ID via `gcloud organizations list`
# Then run `gcloud access-context-manager policies list --organization [ORGANIZATION_ID]`
# The access_policy_number value will be the NAME column
access_policy_number = 250001080040

geolocation = "us"
region      = "us-east4"

# Gemini Enterprise Identity Provider ("GSUITE" or "THIRD_PARTY")
acl_idp_type = "GSUITE"
# If "THIRD_PARTY", set the acl_workforce_pool_name (i.e. locations/global/workforcePools/[WORKFORCE_POOL_NAME]) and acl_workforce_provider_id (without "acl_workforce_pool_name" prefix)
# acl_workforce_pool_name = "locations/global/workforcePools/[WORKFORCE_POOL_NAME]"
# acl_workforce_provider_id = "[WORKFORCE_PROVIDER_ID]"

# If GSUITE, provide the Google Group name using IAM syntax (i.e. "group:[GROUP_NAME]@[DOMAIN]")
# If THIRD_PARTY, provide the Workforce Identity Federation principalSet (i.e. "principalSet://iam.googleapis.com/locations/global/workforcePools/[WORKFORCE_POOL_ID]/group/[GROUP_ID]")
admin_group = "group:gcp-gemini-enterprise-admins@customer-domain.com"
user_group  = "group:gcp-gemini-enterprise-users@customer-domain.com"

# Security
# Enable Chrome Enterprise Premium (Zero Trust) features
enable_chrome_enterprise_premium = false
# KMS Key ID for CMEK encryption (must be in the same location as geolocation)
kms_key_id = "projects/prefx-main-xxx-x/locations/us/keyRings/prefx-gemini-keyring/cryptoKeys/prefx-gemini-key"
create_resource_keys = false # Set to true to create a separate key for resources in Greenfield

# Data Stores
create_data_stores = true

# GCS Data Stores (leave list empty [] if no GCS Data Stores are required)
gcs_data_store_names = ["company-docs", "knowledge-base", "team-playbooks"]

# BigQuery Data Stores (leave list empty [] if no BigQuery Data Stores are required)
bq_data_store_configs = [
  {
    dataset_id = "internal_wiki"
    table_id   = "articles_v2"
  },
  {
    dataset_id = "product_data"
    table_id   = "specs_latest"
  },
  {
    dataset_id = "support_tickets"
    table_id   = "tickets_archive"
  },
]

# Gemini Enterprise Application Load Balancer type ("internal" or "external")
# By default, "external" follows the CNAP architecture, which utilizes external ingress
deployment_type = "external"

# OPTIONAL: If deployment_type is "internal", enter an IP Address CIDR block for the 
# Internal Load Balancer subnet that does not conflict with any on-premise subnet IP ranges.
# internal_lb_subnet_range = "10.10.10.0/24"

# OPTIONAL: A list of allowed IP Address CIDR blocks that will be used
# in Cloud Armor rules and Access Context Manager access policies
# to deny access to all traffic outside of these ranges
# allowed_ip_ranges = [
#   "000.000.000.000/24",
#   "111.111.111.111/24"
# ]

# OPTIONAL: Business start/end times and start/end days of the week
# that will be used in Access Context Manager access policies to deny access
# to all traffic outside of business hours
access_start_hour = 9  # e.g., 9 AM ET
access_end_hour   = 17 # e.g., 5 PM ET
access_start_day  = 1  # Monday
access_end_day    = 5  # Friday

# OPTIONAL: Shared VPC Configuration
# Set use_shared_vpc to true to use an existing Shared VPC
use_shared_vpc = false
# Required if use_shared_vpc is true:
# network_project_id = "host-project-id"
# shared_vpc_network_name = "shared-vpc-network"
# shared_vpc_subnet_name = "landing-default"
# shared_vpc_proxy_subnet_name = "landing-proxy"
